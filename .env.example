# ============================================================
# SkyCast — Environment Variables
# Copy this file to ".env" and adjust values as needed.
# Never commit your real ".env" file to version control.
#
# NOTE: SkyCast uses the free Open-Meteo API, which requires
# NO API key, sign-up, or credit card. There is nothing to
# fill in for weather access -- these variables just control
# app behavior.
# ============================================================

# Flask secret key (used for session signing, e.g. remembering your
# last searched city). Use a long random string in production.
SECRET_KEY=change-this-to-a-random-secret-value

# Set to "True" for local development, "False" in production.
FLASK_DEBUG=True

# Units for temperature/wind: "metric" (°C, m/s) or "imperial" (°F, mph).
UNITS=metric

# The city shown on the dashboard before any search is performed.
DEFAULT_CITY=London
